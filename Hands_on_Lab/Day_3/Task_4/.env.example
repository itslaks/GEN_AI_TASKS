# ─── Groq API ─────────────────────────────────────────────────────────────────
# Obtain your key from https://console.groq.com/keys
# NEVER commit real keys to version control.
GROQ_API_KEY=your_groq_api_key_here

# ─── Flask ────────────────────────────────────────────────────────────────────
# Change to a long random string before deploying to production.
FLASK_SECRET_KEY=change-me-to-a-long-random-string

# ─── ChromaDB ─────────────────────────────────────────────────────────────────
# Local directory for persistent vector storage.
CHROMA_PERSIST_DIR=./chroma_db

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Override default thresholds if needed (optional).
RATE_LIMIT_RUN=10 per minute
RATE_LIMIT_STATUS=60 per minute

# ─── Fallback mode ────────────────────────────────────────────────────────────
# Set to "1" to force the stub/fallback LLM (skips Groq API entirely).
FORCE_FALLBACK=0
