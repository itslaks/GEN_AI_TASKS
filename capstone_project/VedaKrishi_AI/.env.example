# Environment Variables for VedaKrishi AI
# ----------------------------------------
# Copy this file to .env.local and fill in your actual API keys
# Never commit .env.local to version control

# ── Required: At least ONE of these must be set ──────────────────────────────

# OpenAI API Key (enables GPT-4o chat, Whisper voice, TTS audio, image analysis)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Groq API Key (fast fallback model — llama-3.1-8b-instant)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your-groq-key-here

# ── Vercel Deployment ─────────────────────────────────────────────────────────
# Add these in: Vercel Dashboard > Your Project > Settings > Environment Variables
# Set scope to "Production", "Preview", and "Development"

# ── Notes ─────────────────────────────────────────────────────────────────────
# - If OPENAI_API_KEY is set, GPT-4o is used (best quality)
# - If only GROQ_API_KEY, llama-3.1-8b-instant is used (faster & cheaper)
# - Voice input/output and image analysis require OPENAI_API_KEY
